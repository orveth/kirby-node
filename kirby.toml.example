# Example kirby config (copy to `kirby.toml` and edit). One file, two entrypoints:
#
#   kirby-node agent --config kirby.toml     # run ONE sovereign agent (the taste / smoke)
#   kirby-node fleet --config kirby.toml     # run the NODE that joins the network + hosts agents
#
# Takes a node from nothing to a live sovereign Kirby agent in the Nostr fleet:
# load-or-mint identity, join the fleet (presence + heartbeat + 9100 lifecycle),
# bootstrap (fund to born) or resume (restore from the latest checkpoint), boot the
# agent in the sandbox, run the v0 checkpoint-aware workload, meter, die when
# broke. A teammate normally edits identity.key_path, relay.url, genome_image, and
# the state paths; everything else defaults.
#
# NOTE: top-level scalar keys (backend, genome_image, workload, mode, agent_id,
# node_id, state_root, max_run_secs) MUST appear BEFORE any [table] header, per TOML rules.

# Which sandbox backend to boot in:
#   auto        -> VZ on macOS-aarch64, Firecracker on Linux (recommended)
#   firecracker -> force Firecracker (Linux)
#   vz          -> force Apple Virtualization (macOS)
backend = "auto"

# The genome image to boot. Use a local image directory (the
# `nix build .#genome-image` output, holding vmlinux + rootfs.squashfs):
genome_image = { path = "./.kirby/genome-image" }
# A prebuilt-artifact URL to fetch + cache is planned (not yet implemented):
# genome_image = { url = "https://example.com/kirby-genome-arm64.tar" }

# The v0 workload: the genome submits an app checkpoint for future resume, then
# stays alive while the host meter charges VM time. Fleet presence is published by
# the daemon on the host side. Earn workloads are the layer after this milestone.
workload = "app-checkpoint"

# bootstrap = fund to born (first run); resume = restore from the latest checkpoint.
mode = "bootstrap"

# The agent id (the `["a",X]` lifecycle tag) and node label (the `["node",X]` tag
# and presence node_id). Defaults are agent-0 / node-1.
agent_id = "agent-0"
node_id  = "node-1"

# The single durable root for ALL node state (treasuries, keystores, agent dirs). A top-level key,
# so it must precede any [table] header. Unset, it resolves to $KIRBY_STATE_ROOT, else
# $XDG_DATA_HOME/kirby, else $HOME/.local/share/kirby -- never a temp dir. Leave it unset for that
# default; the explicit ./.kirby paths below also work for a single agent.
# state_root = "/var/lib/kirby"

# The run safety ceiling in seconds: an agent that never goes broke halts here. A top-level key.
# Omit for the 600s default; raise it for a long-lived die-when-broke run (0 is rejected).
# max_run_secs = 600

[identity]
# This node's BIP340 Nostr secret key. Minted (0600) on first run, loaded after, so
# the node keeps the SAME npub across restarts. May be a file or a directory.
key_path = "./.kirby/state/node.nostr.key"
# The persisted, daemon-owned treasury directory (defaults to key_path's parent).
treasury_dir = "./.kirby/state/treasury"

[relay]
# The fleet relay websocket URL (ws:// or wss://).
url = "ws://185.18.221.222:7777"
# Seconds between presence beacon re-publishes, and the staleness threshold.
presence_interval_secs = 15
presence_stale_after_secs = 45

[funding]
# Initial treasury balance in sats, seeded only on first creation (play-money for
# the spike; real funds are gated). A resume keeps the persisted balance.
initial_sats = 1000000

# --- Running a NODE (kirby-node fleet) ------------------------------------------------------
# Everything above runs ONE agent. To run a node that joins the network and HOSTS agents, add a
# [fleet] block and run `kirby-node fleet --config kirby.toml`. A bare fleet node (no tenants,
# empty allowlists) joins and listens but hosts nothing until you declare tenants below or an
# operator sends a spawn-request. Every key (plus the capable workload and [brain]/[memory]/
# [agent]/[meter] blocks) is documented in docs/config.md.
#
# [fleet]
# max_tenants = 16             # per-host tenant ceiling
#
# Statically declare the agents this node hosts (each becomes a child kirby-node agent):
# [[fleet.tenants]]
# agent_id = "agent-a"
# initial_sats = 50000
#
# The kind-31003 spawn control plane runs whenever `kirby-node fleet` runs (there is no enable
# flag); it is gated by these allowlists:
# [fleet.spawn]
# # SECURITY: an EMPTY operators list means ANY signer may spawn an agent on this node (a known
# # MVP DoS vector). Allowlist the operator pubkeys you trust before exposing the node.
# operators = ["<operator-pubkey-hex>"]
# # The pre-staged genome images this node will run. EMPTY = spawn nothing (the safe backstop).
# image_allowlist = ["<image-ref>"]
# # OPT-IN: drop spawn requests older than N seconds (sheds stale/parked ones). Omit = off.
# # Do NOT set 0 to mean off -- 0 rejects ALL spawn requests. Use a positive value.
# request_max_age_secs = 3600
